//Scope resolution operator and namespace demo
#include <iostream>
using namespace std;
int x=10;//global variable
namespace demo
{
	int x=20;
	
 }
 main(){
 	int x=100;
 	cout<<"Global variable value x:"<<x<<endl;
 	cout<<"namespace variable value x:"<<demo::x<<endl;
 	cout<<"scope resolution variable value x:"<<x;
 } 
