//Quadratic Equations
#include <iostream>
#include <cmath> 
using namespace std;

int main() { 
	double a, b, c, d, r1, r2; 
	
	cout << "Enter a, b and c values: ";
	cin >> a >> b >> c; 
	
	d = (b * b) - (4 * a * c);
	
	if (d > 0) {

		r1 = (-b + sqrt(d)) / (2.0 * a); 
		r2 = (-b - sqrt(d)) / (2.0 * a); 
		
		cout << "Roots are real and different:\n";
		cout << "Root 1 is: " << r1 << "\n";
		cout << "Root 2 is: " << r2 << "\n";
		
	} else if (d == 0) {
		r1 = -b / (2.0 * a);
		cout << "Roots are real and equal:\n";
		cout << "Root is: " << r1 << "\n";
		
	} else {
		
		cout << "Roots are imaginary/complex:\n";
		cout << "Root 1 is: " <<r1;
		cout << "Root 2 is: " <<r2;
	}
	
	return 0; 
}
